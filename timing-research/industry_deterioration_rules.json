{
  "_comment": "行业恶化链条规则表 - 财报验证层核心逻辑",
  "_version": "v1 2026-04-05",
  "_usage": "每个行业定义两套标准：截面差(bad_when) + 变得更差(worse_when)。验证层用 worse_when 判断恶化是否被财报验证。",
  "industries": {
    "建筑工程": {
      "type": "订单回款型",
      "core_risk": "回款慢、应收膨胀、资金链收紧",
      "bad_when": [
        "应收账款/营收 > 40%",
        "经营现金流为负",
        "货币资金 < 短期借款"
      ],
      "worse_when": [
        "应收账款同比继续抬升",
        "经营现金流继续恶化或由正转负",
        "货币资金/短债覆盖继续下降",
        "合同资产+应收+其他应收同步膨胀"
      ],
      "not_worse_if": [
        "应收虽高但回款加速（CFO改善）",
        "短债压力高但有新融资覆盖"
      ],
      "key_fields": ["accounts_receiv", "n_cashflow_act", "money_cap", "st_borr", "total_liab"]
    },
    "环境保护": {
      "type": "订单回款型",
      "core_risk": "政府应收账款长期挂账、现金流弱",
      "bad_when": [
        "应收账款/营收 > 50%",
        "经营现金流持续为负",
        "资产负债率 > 65%"
      ],
      "worse_when": [
        "应收继续抬升且账龄拉长",
        "CFO继续恶化",
        "新增融资无法覆盖到期债务"
      ],
      "not_worse_if": [
        "政府回款加速，CFO改善"
      ],
      "key_fields": ["accounts_receiv", "n_cashflow_act", "money_cap", "st_borr"]
    },
    "半导体": {
      "type": "高研发成长型",
      "core_risk": "库存堆积、现金消耗、商业化兑现弱",
      "bad_when": [
        "存货/营收 > 60%",
        "经营现金流为负且无改善趋势",
        "货币资金覆盖不足12个月运营"
      ],
      "worse_when": [
        "存货继续堆积，周转天数拉长",
        "现金储备继续下降",
        "收入增速低于研发投入增速",
        "应收+存货同步恶化（不只是研发投入问题，经营链条也失控）"
      ],
      "not_worse_if": [
        "亏损扩大但收入加速兑现",
        "现金流为负但融资能力强、现金储备充足",
        "存货高但是战略备货，周转未恶化"
      ],
      "key_fields": ["inventories", "n_cashflow_act", "money_cap", "accounts_receiv", "q_sales_yoy"]
    },
    "生物制药": {
      "type": "高研发成长型",
      "core_risk": "商业化兑现慢、现金消耗快、融资依赖高",
      "bad_when": [
        "持续亏损且收入兑现弱",
        "经营现金流持续为负",
        "货币资金 < 18个月运营消耗"
      ],
      "worse_when": [
        "亏损扩大且收入不及预期",
        "现金储备继续下降",
        "短期偿债能力变差",
        "研发管线无新进展但费用继续高企"
      ],
      "not_worse_if": [
        "亏损但有重磅产品商业化加速",
        "现金流为负但刚完成大额融资"
      ],
      "key_fields": ["n_cashflow_act", "money_cap", "st_borr", "q_sales_yoy", "q_dtprofit_yoy"]
    },
    "化学制药": {
      "type": "高研发成长型",
      "core_risk": "集采压价、毛利率下滑、研发投入回报不确定",
      "bad_when": [
        "毛利率持续下滑",
        "经营现金流转弱",
        "应收账款拉长"
      ],
      "worse_when": [
        "毛利率继续下滑且无新品放量",
        "CFO继续恶化",
