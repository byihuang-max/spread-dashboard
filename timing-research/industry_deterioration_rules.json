      ],
      "not_worse_if": [
        "集采影响已消化，新品开始放量",
        "毛利率下滑但规模效应抵消"
      ],
      "key_fields": ["n_cashflow_act", "accounts_receiv", "inventories", "q_sales_yoy"]
    },
    "普钢": {
      "type": "周期重资产型",
      "core_risk": "产能过剩、价格下行、杠杆高",
      "bad_when": [
        "资产负债率 > 70%",
        "经营现金流为负",
        "存货跌价压力大"
      ],
      "worse_when": [
        "钢价继续下行且库存继续积压",
        "CFO持续为负",
        "杠杆继续抬升，再融资能力下降"
      ],
      "not_worse_if": [
        "周期底部正常承压，但资产负债表未进一步恶化",
        "钢价企稳，库存开始去化"
      ],
      "key_fields": ["inventories", "n_cashflow_act", "total_liab", "total_assets", "money_cap", "st_borr"]
    },
    "化工原料": {
      "type": "周期重资产型",
      "core_risk": "价格波动、库存周期、资金链",
      "bad_when": [
        "存货/营收 > 30%",
        "经营现金流弱",
        "资产负债率 > 65%"
      ],
      "worse_when": [
        "库存继续积压，周转天数拉长",
        "CFO继续恶化",
        "短债压力抬升"
      ],
      "not_worse_if": [
        "库存高但价格企稳，去化预期改善"
      ],
      "key_fields": ["inventories", "n_cashflow_act", "money_cap", "st_borr"]
    },
    "证券": {
      "type": "金融资产负债表型",
      "core_risk": "市场波动影响收益、资本约束、风险敞口",
      "bad_when": [
        "手续费+投资收益同比明显下滑",
        "风险资产规模快速扩张",
        "净资本充足率下降"
      ],
      "worse_when": [
        "核心业务收益继续恶化",
        "风险敞口继续扩大",
        "资本约束进一步收紧"
      ],
      "not_worse_if": [
        "资产负债率高是正常业务结构（客户保证金），不代表风险",
        "经营现金流为负是正常业务特征，不代表危险"
      ],
      "key_fields": ["q_sales_yoy", "q_dtprofit_yoy", "total_liab", "total_assets"],
      "_warning": "绝不能用普通企业的资产负债率/经营现金流口径判断券商"
    },
    "银行": {
      "type": "金融资产负债表型",
      "core_risk": "资产质量、不良率、净息差收窄",
      "bad_when": [
        "不良率上升",
        "净息差持续收窄",
        "拨备覆盖率下降"
      ],
      "worse_when": [
        "不良率继续上升",
        "净息差继续收窄且无改善预期",
        "拨备覆盖率继续下降"
      ],
      "not_worse_if": [
        "资产负债率高是正常银行结构",
        "经营现金流口径对银行无意义"
      ],
      "key_fields": ["q_sales_yoy", "q_dtprofit_yoy"],
      "_warning": "银行需要专用字段（不良率/拨备），当前快照字段覆盖不足，验证能力有限"
    },
    "多元金融": {
      "type": "金融资产负债表型",
      "core_risk": "资产质量、杠杆、流动性",
      "bad_when": [
        "资产质量恶化",
        "短期流动性压力大",
        "核心业务收益下滑"
      ],
      "worse_when": [
        "资产质量继续恶化",
        "流动性压力继续抬升",
        "核心收益继续下滑"
      ],
      "not_worse_if": [
        "资产负债率高是正常业务结构"
      ],
      "key_fields": ["q_sales_yoy", "q_dtprofit_yoy", "money_cap", "st_borr"],
      "_warning": "金融类行业统一口径有限，需要专用字段"
    },
    "食品": {
      "type": "消费渠道型",
      "core_risk": "渠道去化弱、存货积压、收入增长失速",
      "bad_when": [
        "存货/营收 > 25%",
        "收入同比负增长",
        "经营现金流转弱"
      ],
      "worse_when": [
        "存货继续积压，周转天数拉长",
        "收入继续下滑",
        "渠道压货迹象加重（应收+存货同步抬升）"
      ],
      "not_worse_if": [
        "存货高但是季节性备货，周转未恶化",
        "收入短期承压但渠道库存已开始去化"
      ],
      "key_fields": ["inventories", "accounts_receiv", "n_cashflow_act", "q_sales_yoy"]
    },
    "软件服务": {
      "type": "高研发成长型",
      "core_risk": "收入增长失速、现金流弱、应收拉长",
      "bad_when": [
        "收入增速持续下滑",
        "经营现金流为负",
        "应收账款/营收 > 40%"
      ],
      "worse_when": [
        "收入继续下滑且无新增长点",
        "CFO继续恶化",
        "应收继续拉长，回款质量下降"
      ],
      "not_worse_if": [
        "收入短期承压但合同负债（预收）在增加，说明订单在积累"
      ],
      "key_fields": ["accounts_receiv", "n_cashflow_act", "q_sales_yoy", "q_dtprofit_yoy"]
    },
    "元器件": {
      "type": "高研发成长型",
      "core_risk": "库存周期、客户集中、现金流",
      "bad_when": [
        "存货/营收 > 40%",
        "经营现金流为负",
        "应收账款拉长"
      ],
      "worse_when": [
        "库存继续积压",
        "CFO继续恶化",
        "应收+存货同步恶化"
      ],
      "not_worse_if": [
        "库存高但下游需求回暖，去化预期改善"
      ],
      "key_fields": ["inventories", "accounts_receiv", "n_cashflow_act", "q_sales_yoy"]
    },
    "电气设备": {
      "type": "订单回款型",
      "core_risk": "应收账款、回款周期、资金链",
      "bad_when": [
        "应收账款/营收 > 35%",
        "经营现金流弱",
        "货币资金 < 短债"
      ],
      "worse_when": [
        "应收继续抬升",
        "CFO继续恶化",
        "短债覆盖继续下降"
      ],
      "not_worse_if": [
        "应收高但回款加速，CFO改善"
      ],
      "key_fields": ["accounts_receiv", "n_cashflow_act", "money_cap", "st_borr"]
    },
    "航空": {
      "type": "周期重资产型",
      "core_risk": "高杠杆、油价敏感、现金流波动",
      "bad_when": [
